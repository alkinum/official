---
import BaseLayout from "../layouts/BaseLayout.astro";
---

<BaseLayout
  title="Page not found | Alkinum"
  description="The requested page could not be found."
  canonicalPath="/404"
  noindex={true}
>
  <main class="not-found">
    <img src="/alkinum-icon.png" width="72" height="72" alt="Alkinum" />
    <p>404 / NOT FOUND</p>
    <h1>Nothing here.</h1>
    <a href="/">Return home</a>
  </main>
</BaseLayout>

<style>
  .not-found {
    display: grid;
    width: 100%;
    min-height: 100svh;
    padding: 2rem;
    place-content: center;
    justify-items: start;
    color: #ecefee;
    background:
      radial-gradient(
        circle at 58% 35%,
        rgba(91, 111, 119, 0.15),
        transparent 30%
      ),
      #090a0a;
  }

  img {
    width: 72px;
    height: 72px;
    margin-bottom: 2rem;
    border-radius: 50%;
  }

  p {
    margin: 0 0 1rem;
    color: #858c8b;
    font-family: "JetBrains Mono Variable", monospace;
    font-size: 0.68rem;
  }

  h1 {
    margin: 0 0 2rem;
    font-size: 4rem;
    line-height: 1;
    letter-spacing: 0;
  }

  a {
    padding-bottom: 0.35rem;
    color: #dce0df;
    font-family: "JetBrains Mono Variable", monospace;
    font-size: 0.7rem;
    text-decoration: none;
    text-transform: uppercase;
    border-bottom: 1px solid #7d8483;
  }

  @media (max-width: 560px) {
    h1 {
      font-size: 3rem;
    }
  }
</style>
