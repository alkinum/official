{
  "$schema": "./node_modules/wrangler/config-schema.json",
  "name": "alkinum-official-site",
  "compatibility_date": "2026-07-13",
  "routes": [
    {
      "pattern": "alkinum.io",
      "custom_domain": true,
    },
    {
      "pattern": "alkinum.com",
      "custom_domain": true,
    },
  ],
  "assets": {
    "directory": "./dist",
    "not_found_handling": "404-page",
  },
}
